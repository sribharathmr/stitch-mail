# ══════════════════════════════════════════════════════════════
# Stitch Mail — Server Environment Variables
# For local dev: copy to server/.env and fill in your values
# For Vercel: add these in Project Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Set to 'production' for Vercel deployment

# ── Supabase (required) ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── Authentication (required) ───────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
COOKIE_MAX_AGE=604800000

# ── SMTP / Email Sending ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password

# ── Google OAuth2 (for Sign in with Google) ─────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# Production (Vercel): https://your-app.vercel.app/api/auth/google/callback

# ── Frontend URL (for CORS and redirects) ───────────────────
CLIENT_URL=http://localhost:5173
# Production (Vercel): https://your-app.vercel.app
# Multiple origins: https://your-app.vercel.app,https://custom-domain.com

# ── Cron Security (optional, for Vercel Cron) ───────────────
CRON_SECRET=your_random_cron_secret

# ── AI / Ollama (local only — not available on Vercel) ──────
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=phi3
OLLAMA_TIMEOUT_MS=30000
